{
  "compilerOptions": {
    "target": "es2016",    
    "module": "commonjs",
    "moduleResolution": "node10",
    "baseUrl": "./",  
    "paths": {
      "*": [
        "node_modules/*"
      ]
    },
    "ignoreDeprecations": "6.0",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    /* Type Checking */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules"],
  "include": ["./src/**/*.ts"]
}
